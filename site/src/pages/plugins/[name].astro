---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import PluginHeader from "../../components/plugin/PluginHeader.astro";
import RepoStats from "../../components/plugin/RepoStats.astro";
import SourceActions from "../../components/plugin/SourceActions.astro";
import InstallSteps from "../../components/plugin/InstallSteps.astro";
import UpdateSteps from "../../components/plugin/UpdateSteps.astro";
import ReportIssue from "../../components/plugin/ReportIssue.astro";
import RecommendedPlugins from "../../components/plugin/RecommendedPlugins.astro";
import {
  getSourceUrl,
  getSourceRepo,
  getSourceLabel,
} from "../../lib/source";
import { readFileSync } from "node:fs";
import { resolve } from "node:path";

export async function getStaticPaths() {
  const marketplacePath = resolve(
    process.cwd(),
    "../.claude-plugin/marketplace.json",
  );
  const marketplace = JSON.parse(readFileSync(marketplacePath, "utf-8"));
  const plugins = marketplace.plugins || [];

  return plugins.map((plugin: any) => ({
    params: { name: plugin.name },
    props: { plugin, allPlugins: plugins },
  }));
}

interface Plugin {
  name: string;
  description: string;
  category: string;
  version?: string;
  license?: string;
  tags?: string[];
  author: { username: string; name?: string; url?: string };
  source: any;
}

const { plugin, allPlugins } = Astro.props as {
  plugin: Plugin;
  allPlugins: Plugin[];
};

const sourceUrl = getSourceUrl(plugin.source);
const sourceLabel = getSourceLabel(plugin.source);
const sourceRepo = getSourceRepo(plugin.source);
const starUrl = sourceRepo ? `https://github.com/${sourceRepo}` : "";
const issueUrl = sourceRepo
  ? `https://github.com/${sourceRepo}/issues/new?title=${encodeURIComponent(
      `[${plugin.name}] `,
    )}`
  : "";

const authorDisplay = plugin.author.name || `@${plugin.author.username}`;
const authorUrl =
  plugin.author.url ||
  (plugin.author.username
    ? `https://github.com/${plugin.author.username}`
    : "");

const categoryColors: Record<string, string> = {
  development: "bg-blue-500/20 text-blue-300",
  testing: "bg-green-500/20 text-green-300",
  devops: "bg-orange-500/20 text-orange-300",
  security: "bg-red-500/20 text-red-300",
  documentation: "bg-purple-500/20 text-purple-300",
  productivity: "bg-yellow-500/20 text-yellow-300",
  data: "bg-cyan-500/20 text-cyan-300",
  design: "bg-pink-500/20 text-pink-300",
  other: "bg-gray-500/20 text-gray-300",
};
const categoryColor = categoryColors[plugin.category] || categoryColors.other;

const authorKey = plugin.author.username;
const sameAuthor = allPlugins.filter(
  (p) => p.name !== plugin.name && p.author?.username === authorKey,
);
const sameRepo = sourceRepo
  ? allPlugins.filter(
      (p) => p.name !== plugin.name && getSourceRepo(p.source) === sourceRepo,
    )
  : [];

const recommendedPool = [
  ...new Map([...sameAuthor, ...sameRepo].map((p) => [p.name, p])).values(),
];
let recommended = recommendedPool;
if (recommended.length === 0) {
  recommended = allPlugins.filter(
    (p) => p.name !== plugin.name && p.category === plugin.category,
  );
}
recommended = recommended.slice(0, 4);

const pageTitle = `${plugin.name} — AgentHub`;
const pageDescription = plugin.description;
---

<Layout title={pageTitle} description={pageDescription}>
  <Navbar />

  <div class="mx-auto w-full max-w-5xl px-4 py-10 flex-1 lg:px-8">
    <a
      href="/"
      class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-white transition-colors mb-6"
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="m15 18-6-6 6-6"></path>
      </svg>
      Back to marketplace
    </a>

    <article
      class="rounded-2xl border border-white/10 bg-gradient-to-b from-white/[0.08] to-white/[0.02] p-6 shadow-lg shadow-black/20 sm:p-8"
    >
      <PluginHeader
        name={plugin.name}
        authorDisplay={authorDisplay}
        authorUrl={authorUrl}
        version={plugin.version}
        license={plugin.license}
        category={plugin.category}
        categoryColor={categoryColor}
      />

      <p class="mb-6 text-lg leading-relaxed text-gray-300">
        {plugin.description}
      </p>

      {plugin.tags && plugin.tags.length > 0 && (
        <div class="mb-6 flex flex-wrap gap-2">
          {plugin.tags.map((tag) => (
            <span class="rounded border border-white/10 bg-white/5 px-2 py-1 text-xs font-medium text-gray-400">
              {tag}
            </span>
          ))}
        </div>
      )}

      {sourceRepo && <RepoStats repo={sourceRepo} />}

      <SourceActions
        sourceUrl={sourceUrl}
        starUrl={starUrl}
        sourceLabel={sourceLabel}
      />
    </article>

    <InstallSteps pluginName={plugin.name} />
    <UpdateSteps pluginName={plugin.name} />

    {issueUrl && <ReportIssue pluginName={plugin.name} issueUrl={issueUrl} />}

    <RecommendedPlugins
      plugins={recommended}
      authorDisplay={authorDisplay}
      category={plugin.category}
    />
  </div>

  <Footer />
</Layout>
