---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import PluginCard from "../../components/PluginCard.astro";
import { readFileSync } from "node:fs";
import { resolve } from "node:path";

export async function getStaticPaths() {
  const marketplacePath = resolve(
    process.cwd(),
    "../.claude-plugin/marketplace.json",
  );
  const marketplace = JSON.parse(readFileSync(marketplacePath, "utf-8"));
  const plugins = marketplace.plugins || [];

  return plugins.map((plugin: any) => ({
    params: { name: plugin.name },
    props: { plugin, allPlugins: plugins },
  }));
}

interface Plugin {
  name: string;
  description: string;
  category: string;
  version?: string;
  license?: string;
  tags?: string[];
  author: { username: string; name?: string; url?: string };
  source: any;
}

const { plugin, allPlugins } = Astro.props as {
  plugin: Plugin;
  allPlugins: Plugin[];
};

function getSourceUrl(source: any): string {
  if (typeof source === "string" || !source) return "";
  switch (source.source) {
    case "github":
      return `https://github.com/${source.repo}`;
    case "url":
    case "git-subdir":
      return (source.url || "").replace(/\.git$/, "");
    case "npm":
      return `https://www.npmjs.com/package/${source.package}`;
    default:
      return "";
  }
}

function getSourceRepo(source: any): string {
  if (typeof source === "string" || !source) return "";
  if (source.source === "github") return source.repo || "";
  if (source.source === "url" || source.source === "git-subdir") {
    const m = (source.url || "").match(/github\.com[/:]([^/]+\/[^/]+?)(?:\.git)?$/);
    return m ? m[1] : "";
  }
  return "";
}

function getSourceLabel(source: any): string {
  if (typeof source === "string" || !source) return "local";
  return source.source === "git-subdir" ? "git" : source.source || "unknown";
}

const sourceUrl = getSourceUrl(plugin.source);
const sourceLabel = getSourceLabel(plugin.source);
const sourceRepo = getSourceRepo(plugin.source);
const authorDisplay = plugin.author.name || `@${plugin.author.username}`;
const authorUrl =
  plugin.author.url ||
  (plugin.author.username
    ? `https://github.com/${plugin.author.username}`
    : "");

const categoryColors: Record<string, string> = {
  development: "bg-blue-500/20 text-blue-300",
  testing: "bg-green-500/20 text-green-300",
  devops: "bg-orange-500/20 text-orange-300",
  security: "bg-red-500/20 text-red-300",
  documentation: "bg-purple-500/20 text-purple-300",
  productivity: "bg-yellow-500/20 text-yellow-300",
  data: "bg-cyan-500/20 text-cyan-300",
  design: "bg-pink-500/20 text-pink-300",
  other: "bg-gray-500/20 text-gray-300",
};
const categoryColor = categoryColors[plugin.category] || categoryColors.other;

const authorKey = plugin.author.username;
const pluginRepo = sourceRepo;

const sameAuthor = allPlugins.filter(
  (p) => p.name !== plugin.name && p.author?.username === authorKey,
);
const sameRepo = pluginRepo
  ? allPlugins.filter(
      (p) => p.name !== plugin.name && getSourceRepo(p.source) === pluginRepo,
    )
  : [];

const recommendedPool = [
  ...new Map(
    [...sameAuthor, ...sameRepo].map((p) => [p.name, p]),
  ).values(),
];

let recommended = recommendedPool;

if (recommended.length === 0) {
  recommended = allPlugins.filter(
    (p) => p.name !== plugin.name && p.category === plugin.category,
  );
}

recommended = recommended.slice(0, 4);

const issueUrl = sourceRepo
  ? `https://github.com/${sourceRepo}/issues/new?title=${encodeURIComponent(
      `[${plugin.name}] `,
    )}`
  : "";

const installMarketplace = "/plugin marketplace add nullorder/agenthub";
const installPlugin = `/plugin install ${plugin.name}@agenthub`;
const updateMarketplace = "/plugin marketplace update agenthub";
const updatePlugin = `/plugin update ${plugin.name}@agenthub`;
const starUrl = sourceRepo ? `https://github.com/${sourceRepo}` : "";

const pageTitle = `${plugin.name} — AgentHub`;
const pageDescription = plugin.description;
---

<Layout title={pageTitle} description={pageDescription}>
  <Navbar />

  <div class="mx-auto w-full max-w-5xl px-4 py-10 flex-1 lg:px-8">
    <a
      href="/"
      class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-white transition-colors mb-6"
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="m15 18-6-6 6-6"></path>
      </svg>
      Back to marketplace
    </a>

    <article
      class="rounded-2xl border border-white/10 bg-gradient-to-b from-white/[0.08] to-white/[0.02] p-6 shadow-lg shadow-black/20 sm:p-8"
    >
      <header class="mb-6 flex flex-wrap items-start justify-between gap-4">
        <div class="min-w-0">
          <h1 class="font-pixel text-3xl font-bold text-white break-words sm:text-4xl">
            {plugin.name}
          </h1>
          <div class="mt-3 flex flex-wrap items-center gap-2 text-sm text-gray-400">
            <span>
              by {authorUrl ? (
                <a
                  href={authorUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-blue-400 hover:underline"
                >
                  {authorDisplay}
                </a>
              ) : (
                <span class="text-white">{authorDisplay}</span>
              )}
            </span>
            {plugin.version && (
              <>
                <span class="text-gray-600">•</span>
                <span class="rounded bg-white/10 px-2 py-0.5 font-mono text-xs text-gray-300">
                  v{plugin.version}
                </span>
              </>
            )}
            {plugin.license && (
              <>
                <span class="text-gray-600">•</span>
                <span class="license-badge rounded px-2 py-0.5 text-xs font-medium">
                  {plugin.license}
                </span>
              </>
            )}
          </div>
        </div>
        <span
          class={`shrink-0 rounded-full px-3 py-1 text-sm font-medium ${categoryColor}`}
        >
          {plugin.category}
        </span>
      </header>

      <p class="mb-6 text-lg leading-relaxed text-gray-300">
        {plugin.description}
      </p>

      {plugin.tags && plugin.tags.length > 0 && (
        <div class="mb-6 flex flex-wrap gap-2">
          {plugin.tags.map((tag) => (
            <span
              class="rounded border border-white/10 bg-white/5 px-2 py-1 text-xs font-medium text-gray-400"
            >
              {tag}
            </span>
          ))}
        </div>
      )}

      <div class="flex flex-wrap items-center gap-3 border-t border-white/5 pt-4">
        {sourceUrl && (
          <a
            href={sourceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg border border-white/10 bg-white/5 px-3 py-1.5 text-sm text-gray-300 transition-colors hover:border-white/20 hover:bg-white/10 hover:text-white"
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
              <polyline points="15 3 21 3 21 9"></polyline>
              <line x1="10" y1="14" x2="21" y2="3"></line>
            </svg>
            View source
          </a>
        )}
        {starUrl && (
          <a
            href={starUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg border border-yellow-400/30 bg-yellow-400/10 px-3 py-1.5 text-sm text-yellow-200 transition-colors hover:border-yellow-300/50 hover:bg-yellow-400/15 hover:text-yellow-100"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
            </svg>
            <span>Star this project on</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.97.11-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.19-3.08-.12-.29-.52-1.47.11-3.06 0 0 .97-.31 3.18 1.18a10.95 10.95 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.24 2.77.12 3.06.74.8 1.19 1.82 1.19 3.08 0 4.42-2.7 5.39-5.27 5.68.41.36.78 1.06.78 2.14 0 1.55-.01 2.8-.01 3.18 0 .31.21.67.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z" />
            </svg>
          </a>
        )}
        <span class="rounded bg-white/10 px-2 py-1 font-mono text-xs text-gray-400">
          {sourceLabel}
        </span>
      </div>
    </article>

    <section class="mt-10">
      <h2 class="font-pixel text-xl font-bold text-white mb-4">Install</h2>
      <p class="mb-4 text-sm text-gray-400">
        Run these commands inside Claude Code. Skip the first step if you've
        already added the AgentHub marketplace.
      </p>

      <ol class="space-y-4">
        <li>
          <div class="mb-2 flex items-center gap-2 text-sm text-gray-400">
            <span
              class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-white/10 text-xs font-semibold text-white"
              >1</span
            >
            <span>Add the AgentHub marketplace (one-time setup)</span>
          </div>
          <div class="install-cmd group relative">
            <pre
              class="overflow-x-auto rounded-lg border border-white/10 bg-black/40 px-4 py-3 font-mono text-sm text-gray-200"
            ><code>{installMarketplace}</code></pre>
            <button
              type="button"
              class="copy-btn absolute right-2 top-2 rounded-md border border-white/10 bg-white/5 px-2 py-1 text-xs text-gray-400 opacity-0 transition-all hover:border-white/20 hover:text-white group-hover:opacity-100"
              data-copy={installMarketplace}
            >
              Copy
            </button>
          </div>
        </li>

        <li>
          <div class="mb-2 flex items-center gap-2 text-sm text-gray-400">
            <span
              class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-white/10 text-xs font-semibold text-white"
              >2</span
            >
            <span>Install the plugin</span>
          </div>
          <div class="install-cmd group relative">
            <pre
              class="overflow-x-auto rounded-lg border border-white/10 bg-black/40 px-4 py-3 font-mono text-sm text-gray-200"
            ><code>{installPlugin}</code></pre>
            <button
              type="button"
              class="copy-btn absolute right-2 top-2 rounded-md border border-white/10 bg-white/5 px-2 py-1 text-xs text-gray-400 opacity-0 transition-all hover:border-white/20 hover:text-white group-hover:opacity-100"
              data-copy={installPlugin}
            >
              Copy
            </button>
          </div>
        </li>
      </ol>
    </section>

    <section class="mt-10">
      <h2 class="font-pixel text-xl font-bold text-white mb-4">Update</h2>
      <p class="mb-4 text-sm text-gray-400">
        Plugins are cached locally. To pull the latest changes for {plugin.name}, refresh the catalog first, then update.
      </p>

      <ol class="space-y-4">
        <li>
          <div class="mb-2 flex items-center gap-2 text-sm text-gray-400">
            <span
              class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-white/10 text-xs font-semibold text-white"
              >1</span
            >
            <span>Refresh the AgentHub catalog</span>
          </div>
          <div class="install-cmd group relative">
            <pre
              class="overflow-x-auto rounded-lg border border-white/10 bg-black/40 px-4 py-3 font-mono text-sm text-gray-200"
            ><code>{updateMarketplace}</code></pre>
            <button
              type="button"
              class="copy-btn absolute right-2 top-2 rounded-md border border-white/10 bg-white/5 px-2 py-1 text-xs text-gray-400 opacity-0 transition-all hover:border-white/20 hover:text-white group-hover:opacity-100"
              data-copy={updateMarketplace}
            >
              Copy
            </button>
          </div>
        </li>

        <li>
          <div class="mb-2 flex items-center gap-2 text-sm text-gray-400">
            <span
              class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-white/10 text-xs font-semibold text-white"
              >2</span
            >
            <span>Apply the update for this plugin</span>
          </div>
          <div class="install-cmd group relative">
            <pre
              class="overflow-x-auto rounded-lg border border-white/10 bg-black/40 px-4 py-3 font-mono text-sm text-gray-200"
            ><code>{updatePlugin}</code></pre>
            <button
              type="button"
              class="copy-btn absolute right-2 top-2 rounded-md border border-white/10 bg-white/5 px-2 py-1 text-xs text-gray-400 opacity-0 transition-all hover:border-white/20 hover:text-white group-hover:opacity-100"
              data-copy={updatePlugin}
            >
              Copy
            </button>
          </div>
        </li>
      </ol>
    </section>

    {issueUrl && (
      <section class="mt-10">
        <h2 class="font-pixel text-xl font-bold text-white mb-2">
          Report an issue
        </h2>
        <p class="mb-4 text-sm text-gray-400">
          Found a bug or have a question about {plugin.name}? Open an issue on
          the plugin's repository.
        </p>
        <a
          href={issueUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border border-red-400/30 bg-red-400/10 px-4 py-2 text-sm font-medium text-red-200 transition-colors hover:border-red-300/50 hover:bg-red-400/15 hover:text-red-100"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
          </svg>
          Report an issue with this plugin
        </a>
      </section>
    )}

    {recommended.length > 0 && (
      <section class="mt-12">
        <h2 class="font-pixel text-xl font-bold text-white mb-1">
          Recommended plugins
        </h2>
        <p class="mb-5 text-sm text-gray-400">
          You might like more plugins by {authorDisplay} or in {plugin.category}
        </p>
        <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {recommended.map((p, i) => (
            <div
              class:list={[
                i === 0 && "contents",
                i === 1 && "hidden sm:contents",
                i === 2 && "hidden lg:contents",
                i === 3 && "hidden xl:contents",
              ]}
            >
              <PluginCard {...p} />
            </div>
          ))}
        </div>
      </section>
    )}
  </div>

  <Footer />
</Layout>

<script>
  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.dataset.copy || "";
      try {
        await navigator.clipboard.writeText(text);
        const original = btn.textContent;
        btn.textContent = "Copied";
        btn.classList.add("text-green-400");
        setTimeout(() => {
          btn.textContent = original;
          btn.classList.remove("text-green-400");
        }, 1500);
      } catch {
        // clipboard permission denied or unavailable
      }
    });
  });
</script>
