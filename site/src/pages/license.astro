---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const mdPath = resolve(process.cwd(), '../LICENSE');
const rawContent = readFileSync(mdPath, 'utf-8');

// Remove the H1-style title line
const content = rawContent.replace(/^MIT License\n/, '');
---

<Layout title="License — AgentHub">
  <Navbar />

  <div class="mx-auto max-w-3xl px-4 py-16 flex-1">
    <h1 class="font-pixel mb-8 text-4xl font-bold text-white">MIT License</h1>
    <pre class="whitespace-pre-wrap text-base leading-relaxed text-gray-300">{content.trim()}</pre>
  </div>

  <Footer />
</Layout>

<style>
  :global(html.light) pre {
    color: #444;
  }
</style>
