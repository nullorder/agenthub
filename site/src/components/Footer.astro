---
import RetroGlobe from './RetroGlobe.astro';

const base = import.meta.env.BASE_URL;
---

<footer class="mt-auto relative border-t border-white/10 bg-white/5 backdrop-blur-xl overflow-x-clip">
  <!-- Giant globe popping out of the footer top-right (desktop only) -->
  <div aria-hidden="true" class="footer-watermark pointer-events-none absolute hidden select-none md:block">
    <RetroGlobe size="footer-watermark-globe" showOrbitText={false} />
  </div>

  <div class="relative mx-auto w-full max-w-7xl px-4 pt-14 pb-8 lg:px-8">
    <!-- Grid: brand · community (md+ only) · about -->
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 md:grid-cols-3 md:gap-8">
      <div class="text-center md:text-left">
        <a href={base} class="inline-flex flex-col items-center gap-2 no-underline sm:flex-row sm:gap-3" aria-label="AgentHub">
          <RetroGlobe size="footer-brand-globe" />
          <span class="font-pixel text-xl font-bold tracking-tight text-white sm:text-2xl">AGENTHUB</span>
        </a>
        <p class="mt-4 max-w-xs text-sm text-gray-400 mx-auto md:mx-0">
          Community-driven plugin marketplace for Claude Code.
        </p>
      </div>

      <div class="hidden md:block">
        <h3 class="mb-4 text-lg font-semibold text-blue-400">Community</h3>
        <ul class="space-y-2 text-base text-gray-400">
          <li>
            <a
              href="https://discord.gg/AJMEeFXxXy"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 hover:text-white transition-colors"
            >
              <svg class="h-4 w-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"
                ><path
                  d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"
                ></path></svg
              >
              Discord
            </a>
          </li>
          <li>
            <a
              href="https://x.com/orderofnull"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 hover:text-white transition-colors"
            >
              <svg class="h-4 w-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"
                ><path
                  d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                ></path></svg
              >
              X / Twitter
            </a>
          </li>
          <li>
            <a
              href="https://github.com/nullorder/agenthub"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 hover:text-white transition-colors"
            >
              <svg class="h-4 w-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"
                ><path
                  d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
                ></path></svg
              >
              GitHub
            </a>
          </li>
        </ul>
      </div>

      <div class="text-center md:text-left">
        <h3 class="mb-4 text-lg font-semibold text-blue-400">About</h3>
        <ul class="space-y-2 text-base text-gray-400">
          <li><a href={`${base}license`} class="hover:text-white transition-colors">MIT License</a></li>
          <li><a href={`${base}privacy`} class="hover:text-white transition-colors">Privacy</a></li>
          <li><a href={`${base}coc`} class="hover:text-white transition-colors">Code of Conduct</a></li>
          <li><a href={`${base}stats`} class="hover:text-white transition-colors">Traffic Stats</a></li>
        </ul>
      </div>
    </div>

    <!-- Mobile-only social icons row (Community section hidden below md) -->
    <div class="mt-10 flex justify-center gap-6 md:hidden">
      <a
        href="https://discord.gg/AJMEeFXxXy"
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-400 hover:text-white transition-colors"
        aria-label="Discord"
      >
        <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"
          ><path
            d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"
          ></path></svg
        >
      </a>
      <a
        href="https://x.com/orderofnull"
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-400 hover:text-white transition-colors"
        aria-label="X / Twitter"
      >
        <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"
          ><path
            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
          ></path></svg
        >
      </a>
      <a
        href="https://github.com/nullorder/agenthub"
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-400 hover:text-white transition-colors"
        aria-label="GitHub"
      >
        <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"
          ><path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
          ></path></svg
        >
      </a>
    </div>

    <div class="mt-12 flex flex-col-reverse items-center gap-4 border-t border-white/5 pt-6 text-sm text-gray-500 sm:flex-row sm:justify-between">
      <span>Built with Astro · by nullorder</span>
      <a
        href="https://github.com/nullorder"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:opacity-80 transition-opacity"
        aria-label="nullorder"
      >
        <img src={`${base}nullorder.png`} alt="nullorder" class="h-8 w-8 rounded-full" />
      </a>
    </div>
  </div>
</footer>

<style is:global>
  .footer-watermark {
    /* Pop the globe out the top of the footer: roughly half of it sits
       above the border, the rest tails into the footer background. */
    top: clamp(-280px, -50%, -120px);
    right: clamp(-40px, 2vw, 40px);
    width: clamp(260px, 36vw, 420px);
    aspect-ratio: 1 / 1;
    opacity: 0.22;
    filter: grayscale(0.2);
  }
  :global(html.light) .footer-watermark {
    opacity: 0.28;
  }
  .footer-watermark-globe {
    width: 100%;
    height: 100%;
  }
  .footer-brand-globe {
    width: 2.25rem;
    height: 2.25rem;
    flex-shrink: 0;
  }
  @media (min-width: 640px) {
    .footer-brand-globe {
      width: 2.75rem;
      height: 2.75rem;
    }
  }
</style>
