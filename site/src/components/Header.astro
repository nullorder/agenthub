---
import AnimatedLogo from "./AnimatedLogo.astro";

interface Props {
  pluginCount: number;
  authorCount: number;
}

const { pluginCount, authorCount } = Astro.props;
---

<header class="mb-10 text-center">
  <div class="mx-auto mb-4">
    <AnimatedLogo size="h-32 w-32 mx-auto" />
  </div>
  <h1 class="font-pixel mb-2 text-6xl font-bold tracking-tight text-white">
    AGENTHUB
  </h1>
  <p class="text-xl text-gray-400">
    Community-driven plugin marketplace for Claude Code
  </p>
  <div
    class="mt-4 flex items-center justify-center gap-6 text-base text-gray-500"
  >
    <span><strong class="text-white">{pluginCount}</strong> plugins</span>
    <span><strong class="text-white">{authorCount}</strong> authors</span>
  </div>
  <div class="mt-4">
    <code
      class="rounded-lg border border-white/10 bg-white/5 backdrop-blur-sm px-3 py-1.5 text-base text-gray-300"
      >/plugin marketplace add nullorder/agenthub</code
    >
  </div>
</header>
