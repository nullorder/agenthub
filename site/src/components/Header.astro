---
import AnimatedLogo from "./AnimatedLogo.astro";

interface Props {
  pluginCount: number;
  authorCount: number;
}

const { pluginCount, authorCount } = Astro.props;
---

<header class="mb-10 text-center">
  <div class="mx-auto mb-4">
    <AnimatedLogo size="h-48 w-48 mx-auto" />
  </div>
  <h1 class="font-pixel mb-2 text-6xl font-bold tracking-tight text-white">
    AGENTHUB
  </h1>
  <p class="text-xl text-gray-400">
    Community-driven plugin marketplace for Claude Code
  </p>
  <div
    class="mt-4 inline-flex items-center gap-2 rounded-lg border border-white/10 bg-white/5 backdrop-blur-sm px-3 py-1.5"
  >
    <code class="text-base text-gray-300"
      >/plugin marketplace add nullorder/agenthub</code
    >
    <button
      id="copy-cmd"
      class="rounded p-1 text-gray-500 hover:text-white transition-colors"
      aria-label="Copy command"
    >
      <svg
        id="copy-icon"
        class="h-4 w-4"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <rect x="9" y="9" width="13" height="13" rx="2"></rect><path
          d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
      </svg>
      <svg
        id="check-icon"
        class="h-4 w-4 hidden text-green-400"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <path d="M20 6L9 17l-5-5"></path>
      </svg>
    </button>
  </div>
  <div class="mt-8 flex items-start justify-center gap-12 sm:gap-20">
    <div class="flex flex-col items-center">
      <span
        class="font-pixel text-4xl sm:text-5xl font-bold leading-none text-white"
      >
        {pluginCount}
      </span>
      <span class="mt-2 text-sm text-gray-400">plugins</span>
    </div>
    <div class="flex flex-col items-center">
      <span
        class="font-pixel text-4xl sm:text-5xl font-bold leading-none text-white"
      >
        {authorCount}
      </span>
      <span class="mt-2 text-sm text-gray-400">authors</span>
    </div>
  </div>

  <script>
    const copyBtn = document.getElementById("copy-cmd");
    const copyIcon = document.getElementById("copy-icon");
    const checkIcon = document.getElementById("check-icon");

    copyBtn.addEventListener("click", () => {
      navigator.clipboard.writeText(
        "/plugin marketplace add nullorder/agenthub",
      );
      copyIcon.classList.add("hidden");
      checkIcon.classList.remove("hidden");
      setTimeout(() => {
        copyIcon.classList.remove("hidden");
        checkIcon.classList.add("hidden");
      }, 2000);
    });
  </script>
</header>
