---
interface Props {
  size?: string;
  animate?: boolean;
}

const { size = 'h-20 w-20', animate = true } = Astro.props;
// Two trailing blanks leave a visible gap before the word loops around again.
const letters = 'AGENTHUB  '.split('');
const step = 360 / letters.length;
---

<div class={`agenthub-logo ${animate ? 'is-animated' : ''} ${size}`}>
  <div class="ahl-scene">
    <!-- Planet + rings (static background) -->
    <svg class="ahl-base" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <radialGradient id="ahl-planet" cx="38%" cy="32%" r="78%">
          <stop offset="0%" stop-color="#C7D2FE" />
          <stop offset="40%" stop-color="#6366F1" />
          <stop offset="100%" stop-color="#2E1065" />
        </radialGradient>
        <linearGradient id="ahl-orbit-grad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#67E8F9" />
          <stop offset="100%" stop-color="#3B82F6" />
        </linearGradient>
      </defs>

      <!-- Back half of ring (behind planet) -->
      <g transform="rotate(-16 256 256)">
        <path d="M 16 256 A 240 90 0 0 1 496 256" fill="none" stroke="url(#ahl-orbit-grad)" stroke-width="12" opacity="0.85" stroke-linecap="round"/>
      </g>

      <!-- Planet -->
      <circle cx="256" cy="256" r="140" fill="url(#ahl-planet)"/>
      <ellipse cx="220" cy="212" rx="42" ry="24" fill="#E0E7FF" opacity="0.22"/>

      <!-- Front half of ring (in front of planet) -->
      <g transform="rotate(-16 256 256)">
        <path d="M 16 256 A 240 90 0 0 0 496 256" fill="none" stroke="url(#ahl-orbit-grad)" stroke-width="12" opacity="0.95" stroke-linecap="round"/>
      </g>
    </svg>

    <!-- Rotating band of letters wrapped around the planet -->
    <div class="ahl-tilt">
      <div class="ahl-text-wrap">
        {letters.map((ch, i) => (
          <span class="ahl-letter" style={`--a: ${i * step}deg`}>{ch}</span>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .agenthub-logo {
    perspective: 800px;
    perspective-origin: 50% 50%;
    container-type: size;
    container-name: ahl;
    display: inline-block;
  }
  .ahl-scene {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
  }
  .ahl-base {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .ahl-tilt {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    transform: rotateZ(-16deg);
  }
  .ahl-text-wrap {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
  }
  .agenthub-logo.is-animated .ahl-text-wrap {
    animation: ahl-spin 14s linear infinite;
  }
  @keyframes ahl-spin {
    from { transform: rotateY(360deg); }
    to   { transform: rotateY(0deg); }
  }
  .ahl-letter {
    position: absolute;
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    transform: rotateY(var(--a)) translateZ(30cqmin);
    transform-origin: center;
    transform-style: preserve-3d;
    backface-visibility: hidden;
    font-family: Pixeled, ui-monospace, monospace;
    color: #F0F9FF;
    text-shadow: 0 0 6px rgba(103, 232, 249, 0.6);
    line-height: 1;
    white-space: nowrap;
  }
  @container ahl (min-width: 0) {
    .ahl-letter { font-size: 7cqmin; }
  }
</style>
