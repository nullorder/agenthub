---
interface Props {
  name: string;
  authorDisplay: string;
  authorUrl: string;
  version?: string;
  license?: string;
  category: string;
  categoryColor: string;
  viewCount: number;
}

const {
  name,
  authorDisplay,
  authorUrl,
  version,
  license,
  category,
  categoryColor,
  viewCount,
} = Astro.props;

const displayedViews = viewCount + 1;
const viewsText = new Intl.NumberFormat("en", {
  notation: "compact",
  maximumFractionDigits: 1,
}).format(displayedViews);
const viewsTitle = `${displayedViews.toLocaleString()} ${
  displayedViews === 1 ? "view" : "views"
} (includes this visit)`;
---

<header class="mb-6 flex flex-wrap items-start justify-between gap-4">
  <div class="min-w-0">
    <h1 class="font-pixel text-3xl font-bold text-white break-words sm:text-4xl">
      {name}
    </h1>
    <div class="mt-3 flex flex-wrap items-center gap-2 text-sm text-gray-400">
      <span>
        by {authorUrl ? (
          <a
            href={authorUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-400 hover:underline"
          >
            {authorDisplay}
          </a>
        ) : (
          <span class="text-white">{authorDisplay}</span>
        )}
      </span>
      {version && (
        <>
          <span class="text-gray-600">•</span>
          <span class="rounded bg-white/10 px-2 py-0.5 font-mono text-xs text-gray-300">
            v{version}
          </span>
        </>
      )}
      {license && (
        <>
          <span class="text-gray-600">•</span>
          <span class="license-badge rounded px-2 py-0.5 text-xs font-medium">
            {license}
          </span>
        </>
      )}
      <span class="text-gray-600">•</span>
      <span
        class={`rounded-full px-2.5 py-0.5 text-xs font-medium ${categoryColor}`}
      >
        {category}
      </span>
    </div>
  </div>
  <span
    class="inline-flex shrink-0 items-center gap-1.5 rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-sm font-medium text-gray-300"
    title={viewsTitle}
    aria-label={viewsTitle}
  >
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path>
      <circle cx="12" cy="12" r="3"></circle>
    </svg>
    <span class="font-mono">{viewsText}</span>
  </span>
</header>
