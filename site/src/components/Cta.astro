---
---

<section class="mt-16 rounded-xl border border-white/10 bg-white/5 backdrop-blur-lg p-8 text-center">
  <h2 class="mb-2 text-xl font-bold text-white">Can't find your favorite plugin?</h2>
  <p class="mb-6 text-sm text-gray-400">Help the community grow by adding it yourself or letting us know.</p>

  <div class="mx-auto grid max-w-2xl gap-4 sm:grid-cols-2">
    <button
      id="add-plugin-btn"
      class="rounded-lg border border-white/10 bg-white/5 p-4 text-left transition-all hover:border-white/20 hover:bg-white/10"
    >
      <p class="mb-1 font-semibold text-white">Add your plugin</p>
      <p class="text-xs leading-relaxed text-gray-400">
        Fork the repo, drop a JSON file in <code class="text-gray-300">plugins/</code>, and open a PR. That's it.
      </p>
    </button>

    <a
      href="https://discord.gg/5YrbwNRGaE"
      target="_blank"
      rel="noopener noreferrer"
      class="rounded-lg border border-white/10 bg-white/5 p-4 text-left transition-all hover:border-white/20 hover:bg-white/10"
    >
      <p class="mb-1 font-semibold text-white">Request on Discord</p>
      <p class="text-xs leading-relaxed text-gray-400">
        Ask the community to add it, or suggest a plugin idea you'd like to see.
      </p>
    </a>
  </div>
</section>

<!-- Modal -->
<div id="add-plugin-modal" class="fixed inset-0 z-50 hidden items-center justify-center">
  <div id="modal-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
  <div class="relative mx-4 w-full max-w-lg rounded-xl border border-white/10 bg-gray-900/95 backdrop-blur-xl p-6 shadow-2xl">
    <button id="modal-close" class="absolute right-4 top-4 text-gray-500 hover:text-white transition-colors" aria-label="Close">
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>

    <h3 class="mb-4 text-lg font-bold text-white">Add your plugin to AgentHub</h3>

    <ol class="space-y-3 text-sm text-gray-300">
      <li class="flex gap-3">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-white/15 bg-white/10 text-xs font-bold text-white">1</span>
        <span><strong class="text-white">Build your plugin</strong> with a valid <code class="rounded bg-white/10 px-1 text-gray-200">.claude-plugin/plugin.json</code> manifest.</span>
      </li>
      <li class="flex gap-3">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-white/15 bg-white/10 text-xs font-bold text-white">2</span>
        <span><strong class="text-white">Fork</strong> the <a href="https://github.com/nullorder/agenthub" target="_blank" rel="noopener noreferrer" class="inline-block rounded border border-white/15 bg-white/10 px-2 py-0.5 text-xs font-medium text-blue-400 hover:bg-white/15 transition-colors">AgentHub repo</a></span>
      </li>
      <li class="flex gap-3">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-white/15 bg-white/10 text-xs font-bold text-white">3</span>
        <span>Create <code class="rounded bg-white/10 px-1 text-gray-200">plugins/your-plugin.json</code> with your plugin's name, source, description, and category.</span>
      </li>
      <li class="flex gap-3">
        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-white/15 bg-white/10 text-xs font-bold text-white">4</span>
        <span><strong class="text-white">Open a PR</strong> — CI validates your entry automatically.</span>
      </li>
    </ol>

    <div class="mt-5 flex gap-3">
      <a
        href="https://github.com/nullorder/agenthub/blob/main/CONTRIBUTING.md"
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 rounded-lg border border-white/15 bg-white/10 py-2 text-center text-sm font-medium text-white transition-colors hover:bg-white/15"
      >
        Read full guide
      </a>
      <a
        href="https://github.com/nullorder/agenthub/fork"
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 rounded-lg bg-blue-600 py-2 text-center text-sm font-medium text-white transition-colors hover:bg-blue-500"
      >
        Fork repo
      </a>
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('add-plugin-btn');
  const modal = document.getElementById('add-plugin-modal');
  const backdrop = document.getElementById('modal-backdrop');
  const closeBtn = document.getElementById('modal-close');

  function openModal() {
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  btn.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
  });
</script>
