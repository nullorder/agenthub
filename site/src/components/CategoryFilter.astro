---
interface Props {
  categories: string[];
}

const { categories } = Astro.props;
---

<div class="flex flex-wrap gap-2" id="category-filters">
  <button
    class="category-btn active rounded-full border border-white/20 bg-white/15 backdrop-blur-sm px-3 py-1 text-xs font-medium text-white transition-colors"
    data-category="all"
  >
    All
  </button>
  {categories.map((cat) => (
    <button
      class="category-btn rounded-full border border-white/10 bg-white/5 backdrop-blur-sm px-3 py-1 text-xs font-medium text-gray-400 transition-colors hover:border-white/20 hover:text-gray-200"
      data-category={cat}
    >
      {cat}
    </button>
  ))}
</div>
