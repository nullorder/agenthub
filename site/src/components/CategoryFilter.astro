---
interface Props {
  categories: string[];
}

const { categories } = Astro.props;

// Always render "other" last, regardless of alphabetical order.
const orderedCategories = [...categories].sort((a, b) => {
  if (a === "other") return 1;
  if (b === "other") return -1;
  return a.localeCompare(b);
});
---

<div
  class="filter-row flex gap-2 overflow-x-auto whitespace-nowrap pb-2 lg:flex-row lg:flex-wrap lg:items-start lg:overflow-visible lg:whitespace-normal lg:pb-0"
  id="category-filters"
>
  <button
    class="category-btn active shrink-0 rounded-full border border-white/20 bg-white/15 backdrop-blur-sm px-3 py-1 text-sm font-medium text-white transition-colors"
    data-category="all"
  >
    All
  </button>
  {orderedCategories.map((cat) => (
    <button
      class="category-btn shrink-0 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm px-3 py-1 text-sm font-medium text-gray-400 transition-colors hover:border-white/20 hover:text-gray-200"
      data-category={cat}
    >
      {cat}
    </button>
  ))}
</div>
