---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-29SJB6X760"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-29SJB6X760');
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="A community-driven plugin marketplace for Claude Code" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style define:vars={{ fontUrl: `url(${base}fonts/Pixeled.ttf)` }}>
      @font-face {
        font-family: 'Pixeled';
        src: var(--fontUrl) format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
    </style>
    <title>{title}</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme') || 'dark';
        var e = t === 'system' ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light') : t;
        document.documentElement.classList.add(e);
      })();
    </script>
  </head>
  <body class="font-nunito text-gray-100 min-h-screen relative flex flex-col">
    <div class="fixed inset-0 -z-10">
      <img src={`${base}bg.webp`} alt="" class="bg-dark h-full w-full object-cover" />
      <img src={`${base}bg-light.png`} alt="" class="bg-light absolute inset-0 h-full w-full object-cover" />
      <div class="bg-overlay absolute inset-0"></div>
    </div>
    <!-- Loader overlay -->
    <div id="loader" class="fixed inset-0 z-[100] flex items-center justify-center bg-gray-950 transition-opacity duration-700">
      <div class="h-36 w-36">
        <svg viewBox="0 0 580 580" xmlns="http://www.w3.org/2000/svg" class="h-full w-full">
          <g transform="translate(290, 290)">
            <g class="animate-spin-slow" style="transform-origin: 0px 0px;">
              <circle cx="0" cy="0" r="195" fill="none" stroke="#2a3545" stroke-width="18"/>
              <circle cx="0" cy="0" r="195" fill="none" stroke="#87CEEB" stroke-width="3" opacity="0.4"/>
              <circle cx="0" cy="0" r="210" fill="none" stroke="#87CEEB" stroke-width="1.5" opacity="0.25"/>
              <circle cx="0" cy="0" r="180" fill="none" stroke="#87CEEB" stroke-width="1.5" opacity="0.25"/>
              <g fill="#87CEEB">
                <g transform="rotate(0)"><rect x="-14" y="-250" width="28" height="65" rx="3"/><polygon points="0,-260 -10,-245 10,-245"/><rect x="-8" y="-188" width="16" height="68" rx="2"/><rect x="-12" y="-145" width="24" height="12" rx="2"/></g>
                <g transform="rotate(45)"><rect x="-14" y="-250" width="28" height="65" rx="3"/><polygon points="0,-260 -10,-245 10,-245"/><rect x="-8" y="-188" width="16" height="68" rx="2"/><rect x="-12" y="-145" width="24" height="12" rx="2"/></g>
                <g transform="rotate(90)"><rect x="-14" y="-250" width="28" height="65" rx="3"/><polygon points="0,-260 -10,-245 10,-245"/><rect x="-8" y="-188" width="16" height="68" rx="2"/><rect x="-12" y="-145" width="24" height="12" rx="2"/></g>
                <g transform="rotate(135)"><rect x="-14" y="-250" width="28" height="65" rx="3"/><polygon points="0,-260 -10,-245 10,-245"/><rect x="-8" y="-188" width="16" height="68" rx="2"/><rect x="-12" y="-145" width="24" height="12" rx="2"/></g>
                <g transform="rotate(180)"><rect x="-14" y="-250" width="28" height="65" rx="3"/><polygon points="0,-260 -10,-245 10,-245"/><rect x="-8" y="-188" width="16" height="68" rx="2"/><rect x="-12" y="-145" width="24" height="12" rx="2"/></g>
                <g transform="rotate(225)"><rect x="-14" y="-250" width="28" height="65" rx="3"/><polygon points="0,-260 -10,-245 10,-245"/><rect x="-8" y="-188" width="16" height="68" rx="2"/><rect x="-12" y="-145" width="24" height="12" rx="2"/></g>
                <g transform="rotate(270)"><rect x="-14" y="-250" width="28" height="65" rx="3"/><polygon points="0,-260 -10,-245 10,-245"/><rect x="-8" y="-188" width="16" height="68" rx="2"/><rect x="-12" y="-145" width="24" height="12" rx="2"/></g>
                <g transform="rotate(315)"><rect x="-14" y="-250" width="28" height="65" rx="3"/><polygon points="0,-260 -10,-245 10,-245"/><rect x="-8" y="-188" width="16" height="68" rx="2"/><rect x="-12" y="-145" width="24" height="12" rx="2"/></g>
              </g>
            </g>
            <g class="animate-spin-slow-reverse" style="transform-origin: 0px 0px;">
              <circle cx="0" cy="0" r="125" fill="#0c1018" stroke="#2a3545" stroke-width="14"/>
              <circle cx="0" cy="0" r="125" fill="none" stroke="#D97757" stroke-width="2.5" opacity="0.6"/>
              <circle cx="0" cy="0" r="112" fill="none" stroke="#D97757" stroke-width="1" opacity="0.3"/>
              <circle cx="0" cy="0" r="80" fill="#0c1018"/>
              <g fill="#D97757">
                <ellipse cx="0" cy="-38" rx="11" ry="19"/>
                <ellipse cx="32.9" cy="19" rx="11" ry="19" transform="rotate(120 32.9 19)"/>
                <ellipse cx="-32.9" cy="19" rx="11" ry="19" transform="rotate(-120 -32.9 19)"/>
              </g>
              <circle cx="0" cy="0" r="8" fill="#D97757"/>
              <g fill="none" stroke="#D97757" stroke-width="2.5" stroke-linecap="round" opacity="0.6">
                <line x1="0" y1="-62" x2="0" y2="-82"/>
                <line x1="53.7" y1="31" x2="71" y2="41"/>
                <line x1="-53.7" y1="31" x2="-71" y2="41"/>
              </g>
            </g>
          </g>
        </svg>
      </div>
    </div>

    <slot />

    <script>
      const start = Date.now();
      window.addEventListener('load', () => {
        const loader = document.getElementById('loader');
        if (!loader) return;
        const elapsed = Date.now() - start;
        const delay = Math.max(0, 2000 - elapsed);
        setTimeout(() => {
          loader.style.opacity = '0';
          loader.addEventListener('transitionend', () => loader.remove());
        }, delay);
      });
    </script>
  </body>
</html>
